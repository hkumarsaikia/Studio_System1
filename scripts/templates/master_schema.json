{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio-system.local/master_schema.json",
  "title": "Studio System Master Video Schema",
  "description": "The canonical schema that all 500 video blueprints must follow.",
  "type": "object",
  "required": ["id", "title", "template", "fps", "width", "height", "category", "accentColor", "scenes"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^video_[0-9]{3}$",
      "description": "Unique video identifier (video_001 through video_500)"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "description": "Video title / topic name"
    },
    "template": {
      "type": "string",
      "enum": ["shorts", "explainer", "infographic", "protest"],
      "description": "Rendering template to use"
    },
    "fps": {
      "type": "integer",
      "minimum": 24,
      "maximum": 60,
      "default": 30
    },
    "width": {
      "type": "integer",
      "minimum": 720,
      "default": 1080
    },
    "height": {
      "type": "integer",
      "minimum": 720,
      "default": 1920
    },
    "category": {
      "type": "string",
      "enum": [
        "EVERYDAY SYSTEMS",
        "MONEY & ECONOMICS",
        "INFORMATION SYSTEMS",
        "POWER & INSTITUTIONS",
        "FUTURE SYSTEMS"
      ]
    },
    "accentColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "scenes": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["text", "duration", "visual", "action", "category", "accentColor"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "subtext": { "type": "string" },
          "duration": { "type": "integer", "minimum": 1, "default": 300 },
          "visual": {
            "type": "string",
            "enum": ["crowd", "icons", "network", "bars", "flow", "city", "animals", "landscape", "none"]
          },
          "action": {
            "type": "string",
            "enum": [
              "slow_zoom_in",
              "pan_right",
              "pan_left",
              "static_focus",
              "dramatic_pull_back",
              "slow_pan_up",
              "slow_pan_down"
            ],
            "description": "Camera movement for this scene"
          },
          "category": { "type": "string" },
          "accentColor": { "type": "string" },
          "palette": {
            "type": "object",
            "properties": {
              "background": { "type": "string" },
              "secondary": { "type": "string" }
            }
          },
          "mood": {
            "type": "string",
            "enum": ["neutral", "stressed", "happy", "thinking"],
            "description": "Person mood for crowd scenes"
          },
          "barValues": { "type": "array", "items": { "type": "number" } },
          "flowLabels": { "type": "array", "items": { "type": "string" } },
          "flowDirection": { "type": "string", "enum": ["horizontal", "vertical"] },
          "networkNodes": { "type": "array", "items": { "type": "string" } },
          "icons": { "type": "array", "items": { "type": "string" } },
          "animals": { "type": "array", "items": { "type": "string" } },
          "crowdCount": { "type": "integer", "minimum": 1 },
          "assetTags": { "type": "array", "items": { "type": "string" } },
          "audio": { "type": "string" },
          "hasAudio": { "type": "boolean" },
          "motion": { "type": "string" },
          "panX": { "type": "number" },
          "panY": { "type": "number" }
        }
      }
    }
  }
}
