{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio-system.local/storyboard.schema.json",
  "title": "Studio System Canonical Storyboard",
  "type": "object",
  "required": [
    "id",
    "topicRef",
    "topic",
    "title",
    "category",
    "templateFamily",
    "defaultProfiles",
    "metadataHints",
    "audioMode",
    "scenePlan"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^video_[0-9]{3}$"},
    "topicRef": {"type": "string", "pattern": "^video_[0-9]{3}$"},
    "topic": {"type": "string", "minLength": 3},
    "title": {"type": "string", "minLength": 3},
    "category": {"type": "string"},
    "accentColor": {"type": "string"},
    "templateFamily": {"type": "string", "enum": ["systems_explainer"]},
    "templateHint": {"type": "string", "enum": ["shorts", "explainer", "infographic", "protest"]},
    "defaultProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["shorts_vertical", "social_square", "youtube_horizontal"]}
    },
    "metadataHints": {"type": "object"},
    "audioMode": {"type": "string", "enum": ["text_only"]},
    "scenePlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sceneId",
          "label",
          "purpose",
          "narrationText",
          "onScreenText",
          "subtext",
          "visualGrammar",
          "assetRefs",
          "cameraIntent",
          "motion",
          "timingHints",
          "profileOverrides"
        ],
        "properties": {
          "sceneId": {"type": "string", "pattern": "^scene_[0-9]{2}$"},
          "label": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "narrationText": {"type": "string", "minLength": 1},
          "onScreenText": {"type": "string", "minLength": 1},
          "subtext": {"type": "string", "minLength": 1},
          "visualGrammar": {
            "type": "string",
            "enum": [
              "hook_tension",
              "icon_pressure",
              "system_map",
              "causal_chain",
              "process_flow",
              "feedback_loop",
              "data_lens",
              "real_world_example",
              "externality",
              "macro_context",
              "takeaway",
              "conclusion"
            ]
          },
          "visual": {"type": "string"},
          "visualDirection": {"type": "string"},
          "assetRefs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "cameraIntent": {"type": "string", "minLength": 1},
          "motion": {"type": "string", "minLength": 1},
          "backgroundMode": {"type": "string"},
          "overlays": {"type": "array", "items": {"type": "string"}},
          "palette": {"type": "object"},
          "mood": {"type": "string"},
          "timingHints": {
            "type": "object",
            "required": ["baseSeconds"],
            "properties": {
              "baseSeconds": {"type": "integer", "minimum": 1},
              "seconds": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": true
          },
          "profileOverrides": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
