{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio-system.local/video.schema.json",
  "title": "Studio System Compiled Video Data",
  "type": "object",
  "required": [
    "id",
    "topicRef",
    "profileId",
    "dataset",
    "title",
    "topic",
    "templateFamily",
    "template",
    "fps",
    "width",
    "height",
    "aspectRatio",
    "timeline",
    "sceneCount",
    "totalDurationSeconds",
    "category",
    "accentColor",
    "platformTargets",
    "layoutProfile",
    "audioMode",
    "metadataHints",
    "scenes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^video_[0-9]{3}$"
    },
    "topicRef": {
      "type": "string",
      "pattern": "^video_[0-9]{3}$"
    },
    "profileId": {
      "type": "string",
      "enum": ["shorts_vertical", "social_square", "youtube_horizontal"]
    },
    "dataset": {
      "type": "string",
      "const": "production"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "topic": {
      "type": "string",
      "minLength": 3
    },
    "templateFamily": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "enum": ["shorts", "explainer", "infographic", "protest"]
    },
    "fps": {
      "type": "integer",
      "minimum": 24,
      "maximum": 60
    },
    "width": {
      "type": "integer",
      "minimum": 720
    },
    "height": {
      "type": "integer",
      "minimum": 720
    },
    "aspectRatio": {
      "type": "string",
      "enum": ["9:16", "1:1", "16:9"]
    },
    "timeline": {
      "type": "object",
      "required": ["mode", "sceneCount", "sceneDurationSeconds", "totalSeconds"],
      "properties": {
        "mode": {"type": "string", "enum": ["segmented", "continuous"]},
        "sceneCount": {"type": "integer", "minimum": 1},
        "sceneDurationSeconds": {"type": "integer", "minimum": 1},
        "totalSeconds": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    },
    "sceneCount": {
      "type": "integer",
      "minimum": 1
    },
    "totalDurationSeconds": {
      "type": "number",
      "minimum": 1
    },
    "category": {
      "type": "string"
    },
    "accentColor": {
      "type": "string"
    },
    "platformTargets": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "layoutProfile": {
      "type": "object",
      "required": ["padding", "titleScale", "subtitleScale", "categoryScale", "visualScale", "textMaxWidth", "textAlign"],
      "properties": {
        "padding": {"type": "number", "minimum": 0},
        "titleScale": {"type": "number", "minimum": 0.1},
        "subtitleScale": {"type": "number", "minimum": 0.1},
        "categoryScale": {"type": "number", "minimum": 0.1},
        "visualScale": {"type": "number", "minimum": 0.1},
        "textMaxWidth": {"type": "number", "minimum": 100},
        "textAlign": {"type": "string"}
      },
      "additionalProperties": true
    },
    "audioMode": {
      "type": "string",
      "enum": ["text_only"]
    },
    "metadataHints": {
      "type": "object"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sceneId",
          "segmentId",
          "label",
          "purpose",
          "narrationText",
          "text",
          "subtext",
          "duration",
          "visual",
          "visualGrammar",
          "action",
          "cameraIntent",
          "category",
          "accentColor",
          "palette",
          "assetTags",
          "visualDirection",
          "backgroundMode",
          "motion",
          "overlays",
          "layout",
          "profileId"
        ],
        "properties": {
          "sceneId": {
            "type": "string",
            "pattern": "^scene_[0-9]{2}$"
          },
          "segmentId": {
            "type": "string",
            "pattern": "^(segment|scene)_[0-9]{2}$"
          },
          "label": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "narrationText": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "subtext": {"type": "string"},
          "duration": {"type": "integer", "minimum": 1},
          "visual": {"type": "string", "minLength": 1},
          "visualGrammar": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "cameraIntent": {"type": "string", "minLength": 1},
          "category": {"type": "string"},
          "accentColor": {"type": "string"},
          "palette": {
            "type": "object",
            "required": ["background", "secondary"],
            "properties": {
              "background": {"type": "string"},
              "secondary": {"type": "string"}
            },
            "additionalProperties": true
          },
          "assetTags": {
            "type": "array",
            "items": {"type": "string"}
          },
          "visualDirection": {"type": "string", "minLength": 1},
          "backgroundMode": {"type": "string", "minLength": 1},
          "motion": {"type": "string", "minLength": 1},
          "overlays": {"type": "array", "items": {"type": "string"}},
          "layout": {
            "type": "object",
            "required": ["padding", "titleScale", "subtitleScale", "categoryScale", "visualScale", "textMaxWidth", "textAlign"],
            "properties": {
              "padding": {"type": "number", "minimum": 0},
              "titleScale": {"type": "number", "minimum": 0.1},
              "subtitleScale": {"type": "number", "minimum": 0.1},
              "categoryScale": {"type": "number", "minimum": 0.1},
              "visualScale": {"type": "number", "minimum": 0.1},
              "textMaxWidth": {"type": "number", "minimum": 100},
              "textAlign": {"type": "string"}
            },
            "additionalProperties": true
          },
          "profileId": {
            "type": "string",
            "enum": ["shorts_vertical", "social_square", "youtube_horizontal"]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
