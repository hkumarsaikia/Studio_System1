{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio-system.local/video.schema.json",
  "title": "Studio System Compiled Video Data",
  "type": "object",
  "required": [
    "id",
    "title",
    "topic",
    "template",
    "fps",
    "width",
    "height",
    "segmentCount",
    "segmentSeconds",
    "category",
    "accentColor",
    "scenes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^video_[0-9]{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "topic": {
      "type": "string",
      "minLength": 3
    },
    "template": {
      "type": "string",
      "enum": ["shorts", "explainer", "infographic", "protest"]
    },
    "fps": {
      "type": "integer",
      "minimum": 24,
      "maximum": 60
    },
    "width": {
      "type": "integer",
      "minimum": 720
    },
    "height": {
      "type": "integer",
      "minimum": 720
    },
    "segmentCount": {
      "type": "integer",
      "minimum": 1
    },
    "segmentSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "category": {
      "type": "string"
    },
    "accentColor": {
      "type": "string"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "segmentId",
          "label",
          "text",
          "subtext",
          "narrationText",
          "duration",
          "visual",
          "action",
          "category",
          "accentColor",
          "palette",
          "assetTags"
        ],
        "properties": {
          "segmentId": {
            "type": "string",
            "pattern": "^segment_[0-9]{2}$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "subtext": {
            "type": "string",
            "minLength": 1
          },
          "narrationText": {
            "type": "string",
            "minLength": 1
          },
          "duration": {
            "type": "integer",
            "minimum": 1
          },
          "visual": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "accentColor": {
            "type": "string"
          },
          "palette": {
            "type": "object",
            "required": ["background", "secondary"],
            "properties": {
              "background": {
                "type": "string"
              },
              "secondary": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "assetTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
