{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studio-system.local/production-manifest.schema.json",
  "title": "Studio System Production Manifest",
  "type": "object",
  "patternProperties": {
    "^video_[0-9]{3}$": {
      "type": "object",
      "required": ["title", "topic", "template", "category", "sceneCount", "segmentCount", "segmentSeconds", "storyboard"],
      "properties": {
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "template": { "type": "string", "enum": ["shorts", "explainer", "infographic", "protest"] },
        "category": { "type": "string" },
        "sceneCount": { "type": "integer", "minimum": 1 },
        "segmentCount": { "type": "integer", "minimum": 1 },
        "segmentSeconds": { "type": "integer", "minimum": 1 },
        "storyboard": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
